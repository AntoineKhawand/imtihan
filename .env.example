# ===========================================
# IMTIHAN — Environment Variables
# Copy this file to .env.local and fill in values
# ===========================================

# --- Google Gemini API ---
# Get from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxx

# --- Firebase (Client) ---
# Get from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=imtihan-xxxxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=imtihan-xxxxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=imtihan-xxxxx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (Server) ---
# From Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the private_key field here (keep the \n characters literal)
FIREBASE_ADMIN_PROJECT_ID=imtihan-xxxxx
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@imtihan-xxxxx.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Resend (Email delivery) ---
# Get a free key at https://resend.com/api-keys — free tier: 100 emails/day.
# RESEND_FROM is optional; defaults to the shared onboarding@resend.dev sender.
# To send from your own domain, verify it in Resend and set RESEND_FROM accordingly.
RESEND_API_KEY=
RESEND_FROM=Imtihan <onboarding@resend.dev>

# --- Stripe (Payments — v1.1) ---
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=price_1TPA7TGbIfsCGCuIHQ6wLXf3

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FREE_EXAM_LIMIT=2
